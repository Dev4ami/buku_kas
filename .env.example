# Token bot dari @BotFather
TELOXIDE_TOKEN=123456:ABC-xxxxxxxx

# Telegram user ID kamu (cek via @userinfobot)
# Bot cuma melayani ID ini — orang lain di-ignore total
OWNER_ID=123456789

# Postgres — pakai hostname internal Docker/Coolify, JANGAN expose ke publik
DATABASE_URL=postgres://keuangan:passwordkuat@postgres:5432/keuangan

# Log level (opsional)
RUST_LOG=info

# --- Dashboard web (built-in) ---
# Password login dashboard. Kalau kosong → dashboard terbuka tanpa auth.
DASHBOARD_PASSWORD=
# Rahasia HMAC untuk cookie sesi. Isi string random panjang (>=32 char).
# JANGAN diganti setelah deploy — semua sesi login lama bakal invalid.
SESSION_SECRET=
# Alamat listen dashboard (default 0.0.0.0:8765)
BIND_ADDR=0.0.0.0:8765
